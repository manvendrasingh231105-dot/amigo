rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global lock default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isProfileOwner(userId, data) {
      return isSignedIn() && (
        request.auth.uid == userId ||
        (request.auth.token.email != null && data.get('email', null) != null && request.auth.token.email == data.email)
      );
    }

    function isSeedUser(userId) {
      return userId in [
        'usr_priya_sharma_gmail_com',
        'usr_arjun_mehta_gmail_com',
        'usr_nisha_patel_gmail_com',
        'usr_rohan_kumar_gmail_com',
        'usr_kavya_reddy_gmail_com'
      ];
    }

    // Admin status is tracked via a dedicated /admins/{email} collection
    // (doc ID = the signed-in user's exact email). This lets rules verify
    // admin status via a direct exists() lookup, since Firestore rules can't
    // derive the "usr_" + sanitized-email document ID used by /users/{id}.
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // These emails mirror the hardcoded admin allowlist in AuthGate.tsx.
    // They're allowed to self-provision their OWN /admins/{email} doc the
    // first time they log in, solving the bootstrap problem (an admin doc
    // normally can only be created by an existing admin, but the very first
    // admin has none yet). They can never create a doc for a DIFFERENT email.
    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email in [
        'manvendrasingh17791@gmail.com',
        'manvendrasingh231105@gmail.com',
        'coordinator.safety@amigo.edu'
      ];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validator blueprints to guarantee type safety and prevent Denial of Wallet payload insertions
    function isValidUser(data) {
      return data.get('id', null) != null
        && data.id is string && data.id.size() <= 128
        && data.get('name', null) != null
        && data.name is string && data.name.size() <= 100
        && data.get('avatar', null) != null
        && data.avatar is string && data.avatar.size() <= 10
        && data.get('avatarColor', null) != null
        && data.avatarColor is string && data.avatarColor.size() <= 100
        && data.get('trustScore', null) != null
        && data.trustScore is number
        && data.get('title', null) != null
        && data.title is string && data.title.size() <= 100
        && data.get('email', null) != null
        && data.email is string && data.email.size() <= 150
        && (data.get('statusText', null) == null || data.statusText is string && data.statusText.size() <= 280)
        && (data.get('statusType', null) == null || data.statusType is string && data.statusType.size() <= 50)
        && (data.get('location', null) == null || data.location is string && data.location.size() <= 100)
        && (data.get('role', null) == null || data.role in ['user', 'admin'])
        && (data.get('meetsCount', null) == null || data.meetsCount is number)
        && (data.get('xp', null) == null || data.xp is number)
        && (data.get('level', null) == null || data.level is number)
        && (data.get('bio', null) == null || data.bio is string && data.bio.size() <= 500);
    }

    function isValidHotspot(data) {
      return data.keys().hasAll(['id', 'name', 'icon', 'activeCount', 'limit', 'description', 'x', 'y'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.icon is string && data.icon.size() <= 50
        && data.activeCount is number
        && data.limit is number
        && data.description is string && data.description.size() <= 200
        && data.x is number
        && data.y is number;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['id', 'title', 'location', 'organizer', 'rsvps', 'maxRsvps', 'startTime', 'isLive'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 150
        && data.location is string && data.location.size() <= 150
        && data.organizer is string && data.organizer.size() <= 100
        && data.rsvps is list
        && data.maxRsvps is number
        && data.startTime is string && data.startTime.size() <= 100
        && data.isLive is bool;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'senderId', 'senderName', 'text', 'timestamp'])
        && data.id is string && data.id.size() <= 128
        && data.senderId is string && data.senderId.size() <= 128
        && data.senderName is string && data.senderName.size() <= 100
        && data.text is string && data.text.size() <= 1000
        && data.timestamp is string && data.timestamp.size() <= 100;
    }

    // 1. Users Profile Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isProfileOwner(userId, incoming()) || isSeedUser(userId)) && isValidUser(incoming());
      // Owners can update their own profile (email must stay fixed).
      // Admins can update ANY profile (block/unblock, clear status, award XP, grant/revoke admin role).
      allow update: if isValidUser(incoming()) && (
        (isProfileOwner(userId, existing()) && incoming().email == existing().email)
        || isAdmin()
      );
      allow delete: if isProfileOwner(userId, existing()) || isAdmin();
    }

    // 1b. Admin registry - doc ID is the admin's exact email address.
    // Existence of a doc here grants that email admin rights everywhere.
    match /admins/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isBootstrapAdmin() && request.auth.token.email == email);
    }

    // 2. Hotspots Metrics (Capacity) - admin-managed only
    match /hotspots/{hotspotId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() && isValidHotspot(incoming());
    }

    // 3. Spontaneous Event Meetups & RSVPs - admin-managed only
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidEvent(incoming());
      allow update: if isAdmin() && isValidEvent(incoming());
      allow delete: if isAdmin();
    }

    // 4. Temporary mesh chats
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming());
    }
  }
}
